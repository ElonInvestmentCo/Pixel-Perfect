modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "--enable-source-maps", "artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/mobile exec expo export --platform web"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start Expo Native App"
mode = "sequential"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 5001/tcp 2>/dev/null; node artifacts/mobile/dev-proxy.cjs & pnpm --filter @workspace/mobile exec expo start --localhost --port 5001 --clear"
waitForPort = 5000

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Expo Native App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API Server"

[[workflows.workflow]]
name = "Start API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
waitForPort = 3000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
appType = "MOBILE_APP_EXPO_NATIVE"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5002
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18115
externalPort = 3003

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
LOG_LEVEL = "info"
EXPO_PUBLIC_API_URL = "http://localhost:3000"

[userenv.development]
PORT = "3000"
EXPO_PUBLIC_BACKEND_URL = "https://ebbc153d-be87-4465-be89-9166f3df9b6e-00-2vao16i2ayviu.janeway.replit.dev"
GOOGLE_CALLBACK_URL = "https://ebbc153d-be87-4465-be89-9166f3df9b6e-00-2vao16i2ayviu.janeway.replit.dev/api/auth/google/callback"

[userenv.production]
PORT = "5000"
GOOGLE_CALLBACK_URL = "https://mayaaujau.replit.app/api/auth/google/callback"
