modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start Expo Native App"
mode = "sequential"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 5001/tcp 2>/dev/null; node artifacts/mobile/dev-proxy.cjs & pnpm --filter @workspace/mobile exec expo start --localhost --port 5001 --clear"
waitForPort = 5000

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Expo Native App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API Server"

[[workflows.workflow]]
name = "Start API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
waitForPort = 3000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
appType = "MOBILE_APP_EXPO_NATIVE"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18115
externalPort = 3003

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "3000"
NODE_ENV = "development"
LOG_LEVEL = "info"
EXPO_PUBLIC_API_URL = "http://localhost:3000"
JWT_SECRET = "511c5c4ff018da25ea0fbf128879df4009b0155b52a885c7a0e30a0e596e69d00fc74e375bbbac9ebac2a09a5e0de815"
